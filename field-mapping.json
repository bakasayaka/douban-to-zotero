        "mapped": true,
        "mapType": "1:1",
        "mapsTo": [
          "zotero.ISBN"
        ],
        "notes": "ISBN-10 和 ISBN-13 均填入"
      },
      {
        "id": "author",
        "label": "作者",
        "mapped": true,
