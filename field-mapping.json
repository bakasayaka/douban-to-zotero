      {
        "id": "publisher",
        "label": "出版社",
        "mapped": true,
        "mapType": "split",
        "mapsTo": [
          "zotero.publisher",
          "zotero.place"
        ],
        "notes": "可能含地名前缀（如「北京：商务印书馆」），需拆分"
