  "mappingTypeSummary": {
    "$description": "映射类型统计。从 Zotero（接收端）视角统计，因为一个 Zotero 字段可能由多个豆瓣字段汇入。",
    "1:1": {
      "count": 9,
      "description": "单映射：一个豆瓣字段直接对应一个 Zotero 字段",
      "examples": [
        "出版日期→Date",
        "页数→Pages",
        "丛书→Series",
        "ISBN→ISBN",
        "URL→URL"
      ]
    },
    "merge": {
      "count": 1,
      "description": "多合一：多个豆瓣字段合并写入同一个 Zotero 字段",
      "examples": [
        "书名+副标题 → Title"
      ]
    },
    "split": {
      "count": 1,
      "description": "一拆多：一个豆瓣字段拆分写入多个 Zotero 字段",
      "examples": [
        "出版社 → Publisher + Place"
      ]
    },
    "multi_source": {
      "count": 1,
      "description": "多源候选：多个豆瓣字段按优先级竞争写入同一 Zotero 字段",
      "examples": [
        "出版社|出品方 → Publisher"
      ]
    },
    "conditional": {
      "count": 1,
      "description": "条件映射：仅在特定条件下激活",
      "examples": [
        "出品方 → Publisher（仅出版社为空时）"
      ]
    },
    "derived": {
      "count": 4,
      "description": "派生映射：Zotero 字段无直接豆瓣源，需从其他字段推断或提取",
      "examples": [
        "Title→Volume",
        "Title→Edition",
        "Publisher→Place",
        "Title字符集→Language"
      ]
    },
    "uncertain": {
      "count": 3,
      "description": "不确定映射：角色对应关系需要人工复核",
      "examples": [
        "编→Editor?",
        "校→Contributor?",
        "主编→SeriesEditor?"
      ]
    },
    "excluded": {
      "count": 5,
      "description": "豆瓣字段无 Zotero 对应，直接丢弃",
      "examples": [
        "标签",
        "内容简介",
        "定价"
      ]
    },
    "none": {
      "count": 2,
      "description": "Zotero 字段无任何豆瓣数据源",
      "examples": [
        "Series Number",
        "# of Volumes"
      ]
    },
    "system": {
      "count": 3,
      "description": "Zotero 系统自动填充",
      "examples": [
        "Date Added",
        "Modified",
        "Accessed"
      ]
    },
    "constant": {
      "count": 1,
      "description": "恒定值：不依赖豆瓣字段，对所有条目填入固定值",
      "examples": [
        "Library Catalogue = \"Douban\""
      ]
    },
    "irrelevant": {
      "count": 9,
      "description": "Zotero 字段与本项目无关",
      "examples": [
        "ISSN",
        "DOI",
        "Archive"
      ]
    }
  }
